{
	"name": "rsp-wtp-ui",
	"displayName": "RSP-WTP UI",
	"description": "Provides a unified UI to interact with runtimes and servers managed over the RSP-WTP protocol.",
	"version": "0.1.0",
	"license": "SEE LICENSE IN LICENSE",
	"publisher": "cabutchei",
	"author": "cabutchei",
	"preview": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/cabutchei/rsp-wtp-ui.git"
	},
	"bugs": "https://github.com/cabutchei/rsp-wtp-ui/issues",
	"engines": {
		"vscode": "^1.54.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"server",
		"runtimes",
		"adapters",
		"RSP"
	],
	"icon": "images/rsp_ui_icon.png",
	"activationEvents": [
		"onCommand:wtp.server.createServer",
		"onCommand:wtp.server.addLocation",
		"onCommand:wtp.server.downloadRuntime",
		"onCommand:wtp.server.startRSP",
		"onCommand:wtp.server.disconnectRSP",
		"onCommand:wtp.server.stopRSP",
		"onCommand:wtp.server.terminateRSP",
		"onCommand:wtp.server.start",
		"onCommand:wtp.server.debug",
		"onCommand:wtp.server.stop",
		"onCommand:wtp.server.terminate",
		"onCommand:wtp.server.restart",
		"onCommand:wtp.server.restartDebug",
		"onCommand:wtp.server.remove",
		"onCommand:wtp.server.output",
		"onCommand:wtp.server.add",
		"onCommand:wtp.server.publishFull",
		"onCommand:wtp.server.publishIncremental",
		"onCommand:wtp.server.startModule",
		"onCommand:wtp.server.stopModule",
		"onCommand:wtp.server.actions",
		"onCommand:wtp.server.syncJavaRuntime",
		"onCommand:wtp.server.deploymentAssembly",
		"onView:com.github.cabutchei.rsp.serversView",
		"onLanguage:plaintext"
	],
	"main": "./out/src/extension",
	"contributes": {
		"commands": [
			{
				"command": "wtp.server.createServer",
				"title": "Create New Server...",
				"icon": "resources/dark/new-server.svg",
				"category": "Servers"
			},
			{
				"command": "wtp.server.addLocation",
				"title": "Add Local Server...",
				"icon": "resources/dark/add-location.svg",
				"category": "Servers"
			},
			{
				"command": "wtp.server.downloadRuntime",
				"title": "Download Server...",
				"category": "Servers"
			},
			{
				"command": "wtp.server.startRSP",
				"title": "Start / Connect to RSP Provider",
				"category": "Servers"
			},
			{
				"command": "wtp.server.disconnectRSP",
				"title": "Disconnect from RSP Provider",
				"category": "Servers"
			},
			{
				"command": "wtp.server.stopRSP",
				"title": "Stop RSP Provider",
				"category": "Servers"
			},
			{
				"command": "wtp.server.terminateRSP",
				"title": "Terminate RSP Provider",
				"category": "Servers"
			},
			{
				"command": "wtp.server.start",
				"title": "Start Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.debug",
				"title": "Debug Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.stop",
				"title": "Stop Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.terminate",
				"title": "Terminate Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.restart",
				"title": "Restart in Run Mode",
				"category": "Servers"
			},
			{
				"command": "wtp.server.restartDebug",
				"title": "Restart in Debug Mode",
				"category": "Servers"
			},
			{
				"command": "wtp.server.remove",
				"title": "Remove Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.output",
				"title": "Show Output Channel",
				"category": "Servers"
			},
			{
				"command": "wtp.server.addDeployment",
				"title": "Add Deployment",
				"category": "Servers"
			},
			{
				"command": "wtp.server.removeDeployment",
				"title": "Remove Deployment",
				"category": "Servers"
			},
			{
				"command": "wtp.server.startModule",
				"title": "Start Module",
				"category": "Servers"
			},
			{
				"command": "wtp.server.stopModule",
				"title": "Stop Module",
				"category": "Servers"
			},
			{
				"command": "wtp.server.publishIncremental",
				"title": "Publish Server (Incremental)",
				"category": "Servers"
			},
			{
				"command": "wtp.server.publishFull",
				"title": "Publish Server (Full)",
				"category": "Servers"
			},
			{
				"command": "wtp.server.actions",
				"title": "Server Actions...",
				"category": "Servers"
			},
			{
				"command": "wtp.server.deploymentAssembly",
				"title": "Deployment Assembly",
				"category": "Servers"
			},
			{
				"command": "wtp.server.editServer",
				"title": "Edit Server",
				"category": "Servers"
			},
			{
				"command": "wtp.server.syncJavaRuntime",
				"title": "Sync Java Runtime",
				"category": "Servers"
			},
			{
				"command": "wtp.server.application.run",
				"title": "Run on Server",
				"category": "Application"
			},
			{
				"command": "wtp.server.application.debug",
				"title": "Debug on Server",
				"category": "Application"
			}
		],
		"views": {
			"explorer": [
				{
					"id": "com.github.cabutchei.rsp.serversView",
					"name": "WTP Servers"
				}
			]
		},
		"menus": {
			"view/title": [
				{
					"command": "wtp.server.createServer",
					"when": "view == com.github.cabutchei.rsp.serversView",
					"group": "navigation"
				}
			],
			"commandPalette": [
				{
					"command": "wtp.server.application.run",
					"when": "never"
				},
				{
					"command": "wtp.server.application.debug",
					"when": "never"
				}
			],
			"view/item/context": [
				{
					"command": "wtp.server.startRSP",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(RSPUnknown|RSPStopped)/",
					"group": "0_server-rspstartstop@1"
				},
				{
					"command": "wtp.server.disconnectRSP",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(RSPConnected)/",
					"group": "0_server-rspstartstop@2"
				},
				{
					"command": "wtp.server.stopRSP",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(RSPStarted|RSPConnected)/",
					"group": "0_server-rspstartstop@2"
				},
				{
					"command": "wtp.server.terminateRSP",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(RSPStarted|RSPStarting|RSPStopping)/",
					"group": "0_server-rspstartstop@2"
				},
				{
					"command": "wtp.server.createServer",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(RSPStarted|RSPConnected)/",
					"group": "0_server-rspstartstop@3"
				},
				{
					"command": "wtp.server.start",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Stopped|Unknown)/",
					"group": "1_server-startstop@1"
				},
				{
					"command": "wtp.server.debug",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^Stopped/",
					"group": "1_server-startstop@2"
				},
				{
					"command": "wtp.server.stop",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Started|Debugging|Unknown)/",
					"group": "1_server-startstop@3"
				},
				{
					"command": "wtp.server.restart",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Started|Debugging)/",
					"group": "1_server-startstop@4"
				},
				{
					"command": "wtp.server.restartDebug",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Started|Debugging)/",
					"group": "1_server-startstop@5"
				},
				{
					"command": "wtp.server.terminate",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Stopping|Started|Stopped|Unknown)/",
					"group": "1_server-startstop@6"
				},
				{
					"command": "wtp.server.remove",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Stopped|Unknown)/",
					"group": "2_server-remove@1"
				},
				{
					"command": "wtp.server.publishIncremental",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Deployable)?(Starting|Started|Debugging|Stopping|Stopped|Unknown)/",
					"group": "3_server-deployments@6"
				},
				{
					"command": "wtp.server.publishFull",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped|Unknown)/",
					"group": "3_server-deployments@7"
				},
				{
					"command": "wtp.server.addDeployment",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped|^Unknown)/",
					"group": "3_server-deployments@1"
				},
				{
					"command": "wtp.server.removeDeployment",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /\\s(Synchronized|[+|-|Full]* Publish|Unknown)/",
					"group": "3_server-deployments@2"
				},
				{
					"command": "wtp.server.startModule",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^Deployable(Stopped)/",
					"group": "3_server-modules@1"
				},
				{
					"command": "wtp.server.stopModule",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^Deployable(Started|Starting)/",
					"group": "3_server-modules@2"
				},
				{
					"command": "wtp.server.output",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped)/",
					"group": "4_server-status@1"
				},
				{
					"command": "wtp.server.downloadRuntime",
					"when": "view == com.github.cabutchei.rsp.serversView && !viewItem",
					"group": "5_rsp@1"
				},
				{
					"command": "wtp.server.addLocation",
					"when": "view == com.github.cabutchei.rsp.serversView && !viewItem",
					"group": "5_rsp@2"
				},
				{
					"command": "wtp.server.actions",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped|Unknown)/",
					"group": "6_server-info@1"
				},
				{
					"command": "wtp.server.editServer",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped|Unknown)/",
					"group": "6_server-info@2"
				},
				{
					"command": "wtp.server.syncJavaRuntime",
					"when": "view == com.github.cabutchei.rsp.serversView && viewItem =~ /^(Starting|Started|Debugging|Stopping|Stopped|Unknown)/",
					"group": "6_server-info@3"
				}
			],
			"explorer/context": [
				{
					"command": "wtp.server.application.run",
					"group": "1_server-application@1"
				},
				{
					"command": "wtp.server.application.debug",
					"group": "1_server-application@2"
				},
				{
					"command": "wtp.server.deploymentAssembly",
					"when": "explorerResourceIsFolder",
					"group": "1_server-application@3"
				}
			]
		},
		"configuration": {
			"type": "object",
			"title": "Servers View",
			"properties": {
				"rsp-wtp-ui.rsp.java.home": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"description": "Specifies the path to a full JDK (version 11 or newer) which will be used to launch the Runtime Server Protocol (RSP) Server, as well as be the default java to launch any Java-based runtimes that the RSP will control.\nOn Windows, backslashes must be escaped, i.e.\n\"rsp-ui.rsp.java.home\":\"C:\\\\Program Files\\\\Java\\\\jdk-11.0.13\"",
					"scope": "window"
				},
				"rsp-wtp-ui.connectors.showChannelOnServerOutput": {
					"type": "boolean",
					"default": true,
					"description": "Show Server's output channel when new text added to output stream."
				},
				"rsp-wtp-ui.newServerWebviewWorkflow": {
					"type": "boolean",
					"default": true,
					"title": "Use webviews when creating a new server",
					"description": "If true, use the webviews workflow when creating a new server. If false, use a series of prompts."
				},
				"rsp-wtp-ui.enableAsyncPublish": {
					"type": "boolean",
					"default": false,
					"description": "Enable asynchronous publishing."
				},
				"rsp-wtp-ui.enableStartServerOnActivation": {
					"type": "array",
					"items": {
						"type": "object",
						"title": "List RSP Servers",
						"properties": {
							"id": {
								"type": "string",
								"description": "Id external RSP Provider"
							},
							"name": {
								"type": "string",
								"description": "Name of external RSP Provider (as seen in Tree View)"
							},
							"startOnActivation": {
								"type": "boolean",
								"description": "Enable automatic start of RSP Server during activation"
							}
						}
					},
					"description": "Specifies which RSP Server have to be automatically started during activation. If option is disabled, user will have to manually start the RSP Server through command palette or context menu"
				}
			}
		},
		"javaExtensions": [
			"bundles/com.github.cabutchei.container.plugin-1.0.0-SNAPSHOT.jar"
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"clean": "rm -rf out || rmdir out /s /q",
		"test": "npm run clean && npm run compile && nyc node ./out/test/unit-tests.js",
		"ui-test": "npm run compile && extest setup-and-run -i out/src/ui-test/allTestsSuite.js -c max",
		"update-deps": "node_modules/.bin/ncu --upgrade --loglevel verbose --packageFile package.json && npm update",
		"coverage:upload": "codecov -f coverage/coverage-final.json",
		"build": "npm run compile",
		"lint": "eslint src test --fix"
	},
	"devDependencies": {
		"@types/glob": "^7.1.3",
		"@types/mocha": "^9.1.1",
		"@types/node": "^15.3.0",
		"@types/sinon": "^10.0.0",
		"@types/vscode": "^1.54.0",
		"@typescript-eslint/eslint-plugin": "^4.29.1",
		"@typescript-eslint/parser": "^4.29.1",
		"chai": "^4.3.4",
		"chai-as-promised": "^7.1.1",
		"eslint": "^7.32.0",
		"glob": "^7.1.7",
		"mocha": "^10.0.0",
		"mocha-jenkins-reporter": "^0.4.8",
		"nyc": "^15.1.0",
		"sinon": "^10.0.0",
		"sinon-chai": "^3.6.0",
		"typescript": "^4.3.5",
		"vscode-extension-tester": "^5.0.0",
		"vscode-test": "^1.5.2"
	},
	"dependencies": {
		"@redhat-developer/vscode-extension-proposals": "^0.0.21",
		"@redhat-developer/vscode-redhat-telemetry": "0.4.2",
		"@redhat-developer/vscode-wizard": "^0.2.28",
		"path": "0.12.7",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"rsp-wtp-client": "0.1.0",
		"tmp": "^0.2.1",
		"rsp-wtp-server-connector-api": "0.1.0"
	},
	"__metadata": {
		"id": "8a56feef-5612-4ee5-ad7f-31d60c30ab32",
		"publisherDisplayName": "Red Hat",
		"publisherId": "eed56242-9699-4317-8bc7-e9f4b9bdd3ff",
		"isPreReleaseVersion": false
	}
}
